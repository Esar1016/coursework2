ArrayList<String> readFile(String filename) throws IOException {
        ArrayList<String> lines = new ArrayList<>();
        BufferedReader reader = new BufferedReader(new FileReader(filename));
        String line;
        while ((line = reader.readLine()) != null) {
                lines.add(line);
        }
        reader.close();
        return lines;
}
